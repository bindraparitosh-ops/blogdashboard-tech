{
  "version": 2,
  "builds": [
    { "src": "api/*.js",          "use": "@vercel/node" },
    { "src": "public/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/auth",     "dest": "/api/auth.js"     },
    { "src": "/api/callback", "dest": "/api/callback.js" },
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/publish",  "dest": "/api/publish.js"  },
    { "src": "/api/blogs",    "dest": "/api/blogs.js"    },
    { "src": "/(.*)",         "dest": "/public/index.html" }
  ]
}
